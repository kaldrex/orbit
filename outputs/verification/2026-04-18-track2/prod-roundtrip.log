=== 1. unauth -> 401 ===
{"error":"Unauthorized"}
status=401

=== 2. valid batch with real API key -> 200 ===
{"ok":true,"accepted":1,"inserted":1,"updated":0}
status=200

=== 3. same event twice -> still 200, updated=1 (idempotent) ===
{"ok":true,"accepted":1,"inserted":0,"updated":1}
status=200

=== 4. bad source enum -> 400 ===
{"error":"invalid batch","details":[{"code":"invalid_value","values":["whatsapp","gmail","calendar","slack","linear"],"path":[0,"source"],"message":"Invalid option: expected one of \"whatsapp\"|\"gmail\"|\"calendar\"|\"slack\"|\"linear\""}],"max_batch":500}
status=400
