[Unit]
Description=Orbit job runner — poll every 15 minutes

[Timer]
# Boot-delayed first tick (5 min after boot), then every 15 min on the
# wall clock. Persistent=true so a missed tick (laptop closed, VM paused)
# fires once the machine is back up.
OnBootSec=5min
OnUnitActiveSec=15min
AccuracySec=30s
Persistent=true
Unit=orbit-job-runner.service

[Install]
WantedBy=timers.target
